// Tween Learning — Prisma Schema
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── PROGRAMS ─────────────────────────────────────────────────────────────────
model Program {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  status      ProgramStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cohorts     Cohort[]
  enrollments Enrollment[]

  @@map("programs")
}

enum ProgramStatus {
  ACTIVE
  COMING_SOON
  ARCHIVED
}

// ─── COHORTS ──────────────────────────────────────────────────────────────────
model Cohort {
  id          String   @id @default(cuid())
  programId   String
  program     Program  @relation(fields: [programId], references: [id])
  name        String   // e.g. "Cohort 1 — July 2025"
  startDate   DateTime
  endDate     DateTime?
  maxSeats    Int      @default(20)
  status      CohortStatus @default(OPEN)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enrollments Enrollment[]

  @@map("cohorts")
}

enum CohortStatus {
  OPEN
  FULL
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ─── STUDENTS / ENROLLMENTS ───────────────────────────────────────────────────
model Enrollment {
  id              String   @id @default(cuid())
  programId       String
  program         Program  @relation(fields: [programId], references: [id])
  cohortId        String?
  cohort          Cohort?  @relation(fields: [cohortId], references: [id])

  // Personal
  firstName       String   @default("")
  lastName        String   @default("")
  email           String
  country         String   @default("")
  background      String   @default("")
  programName     String   @default("")

  // Meta
  status          EnrollmentStatus @default(PENDING)
  ipAddress       String?
  userAgent       String?
  source          String?   // utm_source etc.
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([email])
  @@index([programId])
  @@index([status])
  @@index([createdAt])
  @@map("enrollments")
}


enum EnrollmentStatus {
  PENDING
  CONFIRMED
  REJECTED
  WAITLISTED
  CANCELLED
}

// ─── WAITLIST ─────────────────────────────────────────────────────────────────
model WaitlistEntry {
  id           String   @id @default(cuid())
  fullName     String
  email        String
  interestArea InterestArea
  gdprConsent  Boolean
  ipAddress    String?
  source       String?
  createdAt    DateTime @default(now())

  @@unique([email, interestArea])
  @@index([email])
  @@index([interestArea])
  @@map("waitlist_entries")
}

enum InterestArea {
  AI
  CYBERSECURITY
  SOFTWARE_ENGINEERING
  CLOUD_COMPUTING
  OTHER
}

// ─── INSTRUCTOR APPLICATIONS ─────────────────────────────────────────────────
model InstructorApplication {
  id                 String   @id @default(cuid())
  fullName           String
  email              String   @unique
  expertiseArea      String
  yearsOfExperience  Int
  linkedinUrl        String?
  proposal           String   @db.Text
  status             ApplicationStatus @default(NEW)
  reviewerNotes      String?  @db.Text
  ipAddress          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@map("instructor_applications")
}

enum ApplicationStatus {
  NEW
  REVIEWING
  ACCEPTED
  REJECTED
}

// ─── CONTACT MESSAGES ─────────────────────────────────────────────────────────
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  ipAddress String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
  @@map("contact_messages")
}
